{
  "name": "incident-hive-backend",
  "version": "1.0.0",
  "description": "Cyber Incident Reporting Mobile App – REST API backend",
  "main": "server.js",
  "author": "Incident Hive Team",
  "license": "ISC",
  "private": true,
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest --runInBand --forceExit",
    "migrate": "node -e \"require('./config/database').runMigrations().then(() => { console.log('Migrations complete'); process.exit(0); }).catch(err => { console.error(err); process.exit(1); })\""
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.600.0",
    "@aws-sdk/lib-storage": "^3.600.0",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "google-auth-library": "^10.6.2",
    "helmet": "^7.1.0",
    "ioredis": "^5.4.1",
    "joi": "^17.13.3",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.14",
    "pg": "^8.12.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^14.0.0",
    "winston": "^3.13.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.1.4",
    "supertest": "^7.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/__tests__/**/*.test.js",
      "**/*.test.js"
    ],
    "coverageDirectory": "coverage",
    "collectCoverageFrom": [
      "controllers/**/*.js",
      "models/**/*.js",
      "services/**/*.js",
      "middleware/**/*.js",
      "!**/node_modules/**"
    ]
  },
  "nodemonConfig": {
    "watch": [
      "*.js",
      "routes/",
      "controllers/",
      "models/",
      "services/",
      "middleware/",
      "config/",
      "utils/"
    ],
    "ext": "js,json",
    "ignore": [
      "node_modules/",
      "uploads/",
      "coverage/",
      "**/*.test.js"
    ],
    "delay": "500"
  }
}

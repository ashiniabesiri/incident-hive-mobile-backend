# ─────────────────────────────────────────────────────────────────────────────
# Incident Hive – Environment Variables Example
#
# ─────────────────────────────────────────────────────────────────────────────

# ── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
API_PREFIX=/api/v1

# Public base URL used to build uploaded file download links.
# No trailing slash.
# Local example: http://localhost:3000
# Production example: https://api.incidenthive.com
BASE_URL=http://localhost:3000

# ── PostgreSQL ───────────────────────────────────────────────────────────────
# Full PostgreSQL connection string.
# Replace YOUR_POSTGRES_PASSWORD with your own local PostgreSQL password in .env.
# Do not put your real password in this .env.example file.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/incident_hive

# Optional PostgreSQL pool size.
DB_POOL_MAX=20

# Optional path to CA certificate for production SSL (rejectUnauthorized: true).
# DB_SSL_CA_PATH=./certs/rds-ca.pem

# ── Redis ────────────────────────────────────────────────────────────────────
# Local Redis URL.
REDIS_URL=redis://localhost:6379

# ── JWT ──────────────────────────────────────────────────────────────────────
# RS256 (recommended) — generate keys with:  node scripts/generate-keys.js
# Then set paths to the generated PEM files:
JWT_PRIVATE_KEY_PATH=./keys/private.pem
JWT_PUBLIC_KEY_PATH=./keys/public.pem

# Alternatively, paste PEM content inline (use \n for newlines):
# JWT_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nMIIEv...
# JWT_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\nMIIBIj...

# HS256 fallback — used only when RSA keys above are not configured.
# Generate secrets with:
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=replace_with_long_random_access_secret
JWT_REFRESH_SECRET=replace_with_long_random_refresh_secret

# Token / session lifetimes in seconds.
# ACCESS_TOKEN_TTL_SECONDS=900 means access token expires after 15 minutes.
# REFRESH_TOKEN_TTL_SECONDS=604800 means refresh token expires after 7 days.
# SESSION_TTL_SECONDS=1800 means inactive session expires after 30 minutes.
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=604800
SESSION_TTL_SECONDS=1800

# ── OTP / MFA ────────────────────────────────────────────────────────────────
# MFA_OTP_TTL_SECONDS=300 means MFA code expires after 5 minutes.
# EMAIL_VERIFICATION_TTL_SECONDS=900 means email verification code expires after 15 minutes.
# PASSWORD_RESET_TTL_SECONDS=900 means password reset code expires after 15 minutes.
MFA_OTP_TTL_SECONDS=300
EMAIL_VERIFICATION_TTL_SECONDS=900
PASSWORD_RESET_TTL_SECONDS=900

# ── Encryption ───────────────────────────────────────────────────────────────
# Use a long random secret in your real .env file.
# The backend hashes this into a 32-byte AES key.
# Generate with:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=replace_with_long_random_encryption_key

# ── Google Login ─────────────────────────────────────────────────────────────
# Required only if Google login is used.
# GOOGLE_CLIENT_ID — iOS OAuth client ID (audience for iOS-issued ID tokens).
# GOOGLE_WEB_CLIENT_ID — Web OAuth client ID used by Android Credential Manager
# as `serverClientId` (audience for Android-issued ID tokens). Either or both
# may be set; the backend accepts tokens whose `aud` matches any configured ID.
GOOGLE_CLIENT_ID=replace_with_google_ios_client_id
GOOGLE_WEB_CLIENT_ID=replace_with_google_web_client_id

# ── Email ────────────────────────────────────────────────────────────────────
# Standard SMTP email sending.
# For Gmail, use an App Password, not your normal Gmail password.
# Example Gmail values:
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USER=your_email@example.com
EMAIL_PASSWORD=your_email_app_password_or_smtp_password
EMAIL_FROM="Incident Hive" <your_email@example.com>

# Brevo / Sendinblue REST API option.
# Set USE_BREVO=true only if using Brevo instead of SMTP.
USE_BREVO=false
BREVO_API_KEY=replace_with_brevo_api_key_if_used

# ── File Storage ─────────────────────────────────────────────────────────────
# local = files saved to ./uploads/incidents
# s3    = files uploaded to AWS S3
FILE_STORAGE=local

# Upload limits.
PROFILE_PICTURE_MAX_MB=5
INCIDENT_ATTACHMENT_MAX_MB=10
MAX_INCIDENT_ATTACHMENTS=5

# AWS S3 settings.
# Only required when FILE_STORAGE=s3.
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=replace_with_aws_access_key_id_if_used
AWS_SECRET_ACCESS_KEY=replace_with_aws_secret_access_key_if_used
S3_BUCKET_NAME=incident-hive-attachments

# ── Rate Limiting ────────────────────────────────────────────────────────────
# RATE_LIMIT_WINDOW_MS=900000 means 15 minutes.
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ── Logging ──────────────────────────────────────────────────────────────────
# Options: error | warn | info | http | verbose | debug | silly
LOG_LEVEL=info

# ── Frontend / CORS ──────────────────────────────────────────────────────────
# For local frontend testing.
# Android emulator may use http://10.0.2.2:3000 to access localhost backend.
# Physical phone testing may need your computer LAN IP, for example:
# http://192.168.1.10:3000
FRONTEND_URL=http://localhost:3001

# ── Push Notifications (FCM) ────────────────────────────────────────────────
# Firebase Cloud Messaging — optional. If neither variable is set, push
# notifications are silently disabled (in-app DB notifications still work).
#
# Option A: path to a Firebase service-account JSON key file.
FCM_SERVICE_ACCOUNT_PATH=./keys/firebase-service-account.json
#
# Option B: inline JSON (useful for Docker / cloud environments).
# FCM_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...",...}